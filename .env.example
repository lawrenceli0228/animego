# MongoDB Atlas 连接字符串
# 注册 https://mongodb.com/atlas 免费获取
MONGODB_URI=mongodb+srv://<用户名>:<密码>@cluster0.xxxxx.mongodb.net/animego

# JWT 密钥（随机字符串，越长越安全）
# 生成命令：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=在这里填入随机字符串
JWT_REFRESH_SECRET=在这里填入另一个随机字符串

# Token 过期时间
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# 服务器端口
PORT=5001

# 前端域名（生产环境填你的真实域名）
# 开发环境：http://localhost:5173
# 生产环境：https://你的域名.com
CLIENT_ORIGIN=http://localhost:5173

# 番剧缓存时长（小时）
CACHE_TTL_HOURS=24

# 弹弹Play API（弹幕功能）
# 申请地址：https://api.dandanplay.net/
DANDANPLAY_APP_ID=在这里填入你的AppId
DANDANPLAY_APP_SECRET=在这里填入你的AppSecret
