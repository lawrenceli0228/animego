# ──────────────────────────────────────────────────────────────────
#  AnimeGo dev .env (post-feat/go-backend rewrite + v2.0.x parallel)
#
#  v2.0.x Express + Mongo still uses MONGODB_URI/JWT_SECRET/PORT/etc.
#  feat/go-backend (Go + Postgres) uses DATABASE_URL/JWT_SECRET/PORT_GO.
#  Both stacks share JWT_SECRET so tokens issued by either verify in either.
# ──────────────────────────────────────────────────────────────────

# ─── Shared ───
# JWT signing key. Same value used by Express, Go, and ws-server.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=fill-with-32-byte-random-hex
JWT_REFRESH_SECRET=fill-with-another-32-byte-random-hex
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Dandanplay API (danmaku matching). Same value for both stacks.
# Apply at https://api.dandanplay.net/
DANDANPLAY_APP_ID=fill-with-your-app-id
DANDANPLAY_APP_SECRET=fill-with-your-secret

# ─── v2.0.x (Express + Mongo) — still drives `main` and prod ───
MONGODB_URI=mongodb://localhost:27017/animego
PORT=5001
CLIENT_ORIGIN=http://localhost:5173
CACHE_TTL_HOURS=24

# ─── feat/go-backend (Go + Postgres) — dev only until cutover ───
# Matches docker-compose.dev.yml default credentials.
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgres://animego:devpassword@localhost:5432/animego?sslmode=disable
PORT_GO=8080
PORT_WS=3001            # ws-server (P2.8)

# ─── Next.js 16 client (P3+) ───
# Once Next replaces Vite, CLIENT_ORIGIN above flips to :3000.
# NEXT_PUBLIC_API_BASE=http://localhost:8080
