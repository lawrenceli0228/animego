# ──────────────────────────────────────────────────────────────────
#  AnimeGo dev .env (Phase 3 — Next.js 16 + Bun on :3000)
#
#  Three services share JWT_SECRET + DATABASE_URL during dev:
#    - go-api    (Go HTTP API on :8080)
#    - ws-server (socket.io danmaku on :3001)
#    - next-app  (Next.js 16 RSC + dev rewrites on :3000)
#
#  v2.0.x Express + Mongo still ships `main` and prod until P9 cutover.
#  Both stacks share JWT_SECRET so tokens issued by either verify in either.
# ──────────────────────────────────────────────────────────────────

# ─── Shared ───
# JWT signing key. Same value used by Express, Go, ws-server, and next-app
# middleware (next-app verifies access tokens server-side for SSR auth).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=<your-jwt-secret-256-bits-hex>
JWT_REFRESH_SECRET=<your-jwt-refresh-secret-256-bits-hex>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Dandanplay API (danmaku matching). Same value for both stacks.
# Apply at https://api.dandanplay.net/
DANDANPLAY_APP_ID=<your-dandanplay-app-id>
DANDANPLAY_APP_SECRET=<your-dandanplay-app-secret>

# ─── v2.0.x (Express + Mongo) — still drives `main` and prod ───
MONGODB_URI=mongodb://localhost:27017/animego
PORT=5001
# CLIENT_ORIGIN is the CORS allow-list consumed by Express, Go API, and ws-server.
# Phase 3: flipped from :5173 (Vite) to :3000 (next-app dev server).
# Old Vite :5173 retires at P10; not running in P3+ dev.
CLIENT_ORIGIN=http://localhost:3000
CACHE_TTL_HOURS=24

# ─── feat/go-backend (Go + Postgres) — dev only until cutover ───
# POSTGRES_PASSWORD seeds the docker-compose.dev.yml Postgres container
# and must match the password inside DATABASE_URL below.
POSTGRES_PASSWORD=devpassword

# DATABASE_URL is the libpq DSN consumed by THREE callers in dev:
#   1. go-api pgxpool        (request handlers + river queue, same pool)
#   2. next-app server actions (when/if a server action queries Postgres directly)
#   3. cmd/migrate            (schema migrations, includes river queue tables 0007+)
# River queue (P2.6 bangumi_v3) has NO separate URL — it shares this pgxpool.
DATABASE_URL=postgres://animego:devpassword@localhost:5432/animego?sslmode=disable

PORT_GO=8080
PORT_WS=3001            # ws-server (P2.8)

# ─── Next.js 16 client (P3+) ───
# next-app dev server runs on :3000 and proxies /api/* to Go :8080 via
# next.config.ts rewrites (same-origin, no CORS). Browser never hits :8080 directly.
#
# Reserved for future use — leave unset in P3.0/P3.1, dev rewrites cover it:
# NEXT_PUBLIC_API_BASE=http://localhost:8080
# NEXT_PUBLIC_WS_BASE=http://localhost:3001
