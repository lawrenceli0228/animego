# ============================================================================
# AnimeGo .env.production template — copy to .env.production on the VPS
# ============================================================================
#
# How to use:
#   1. cp .env.production.template .env.production
#   2. Fill in every "REPLACE_ME_..." secret (generate strong 32+ char values
#      with `openssl rand -hex 32` or `pwgen -s 48 1`)
#   3. chmod 600 .env.production
#   4. Build with the env file:
#        docker compose --env-file=.env.production build
#      Then bring services up:
#        docker compose --env-file=.env.production up -d
#
# Sensitivity tags:
#   [SECRET]  must not leak; rotate if exposed
#   [INFRA]   non-secret but environment-specific
#   [BUILD]   read at `docker compose build` (not at runtime); the value is
#             baked into the image / inlined into the client bundle. Changing
#             requires a rebuild, NOT just a restart.
#
# Service columns (who reads it):
#   E = Express (server/)            — legacy stack, retired at P9 cutover +30d
#   N = next-app (Next.js 16 RSC)
#   W = ws-server (socket.io)
#   G = go-api (Go HTTP)
#   D = docker-compose interpolation (${VAR})
#
# Notes on docker-compose overrides:
#   - compose's `environment:` block per service overrides values pulled in
#     via `env_file:`. Where compose already pins a value (PORT_GO=8080,
#     PORT_WS=3001, TZ=Asia/Shanghai, HOSTNAME=0.0.0.0, NODE_ENV=production
#     for next-app), entries here are belt-and-suspenders for non-compose
#     runs and for services without a per-service override.
#   - DATABASE_URL is overridden ONLY for go-api (compose constructs it from
#     POSTGRES_PASSWORD). ws-server has NO compose override → it reads the
#     literal DATABASE_URL from this file. Keep DATABASE_URL set here.

# ============================================================================
# 1. Database
# ============================================================================

# [SECRET] [D]  required — Postgres password used by the `postgres` service
# and interpolated by docker-compose into DATABASE_URL for go-api.
# Generate: `openssl rand -hex 24`. Must NOT contain '@' '/' ':' '?' (would
# break the libpq URL). 32+ chars recommended.
POSTGRES_PASSWORD=REPLACE_ME_postgres_password_32+chars_no_at_slash_colon

# [SECRET] [W G]  required for ws-server, ignored by go-api (compose overrides).
# Literal libpq connection string. ws-server reads this AS-IS from .env.production
# because its compose block has no DATABASE_URL override. The value MUST stay in
# sync with POSTGRES_PASSWORD above — if you rotate the password, update both.
# Hostname `postgres` is the Docker service name (resolved by Docker DNS).
DATABASE_URL=postgres://animego:REPLACE_ME_SAME_AS_POSTGRES_PASSWORD@postgres:5432/animego?sslmode=disable

# [INFRA] [E]  required while Express + Mongo are still live (until P9 +30d).
# Rollback safety net during the cutover window. Remove after Mongo retires.
MONGODB_URI=mongodb://mongodb:27017/animego

# ============================================================================
# 2. JWT + auth
# ============================================================================

# [SECRET] [E N W G]  required — shared HS256 access-token secret. The single
# login token must verify across Express, go-api, ws-server, AND next-app
# middleware. Rotating invalidates EVERY session, including refresh-on-next-
# request flows. Coordinate rotation.
# Generate: `openssl rand -hex 32`.
JWT_SECRET=REPLACE_ME_jwt_access_secret_64+hex_chars

# [SECRET] [E G]  required — distinct refresh-token secret. Using a separate
# value means a leaked access token can't be re-signed as a refresh.
# Generate: `openssl rand -hex 32`.
JWT_REFRESH_SECRET=REPLACE_ME_jwt_refresh_secret_64+hex_chars

# [INFRA] [E G]  Access-token lifetime. 60m matches the OAuth norm
# (Google / Okta / Cognito access tokens are all ~1h). proxy.ts silently
# refreshes ~30s before expiry off the token's own exp, so this is invisible
# to users. Format: Go-style duration ("60m", "1h") OR "7d" shorthand.
JWT_EXPIRES_IN=60m

# [INFRA] [E G]  Refresh-token + cookie maxAge = effective "免登录" window
# (sliding; rotated on every refresh). 30d targets the consumer-content norm
# for a binge-watch site — short enough to revoke, long enough that returning
# viewers don't get logged out between episodes. (B站 ~180d, Netflix 365d.)
JWT_REFRESH_EXPIRES_IN=30d

# [INFRA] [E]  P9 CUTOVER GATE. Set to "1" to freeze new user registration
# (server/routes/auth.routes.js short-circuits POST /auth/register with 403
# when this is truthy). Leave empty / unset to allow signups.
# Plan: set to "1" 24h BEFORE P9 cutover so no new accounts land in Mongo
# without also landing in Postgres. Unset after the migration backfill runs.
REGISTER_DISABLED=

# ============================================================================
# 3. Email (Gmail SMTP via nodemailer + go-api)
# ============================================================================
# Both Express and go-api read these. If EITHER is empty, the password-reset
# email path is silently skipped — forgot-password still returns 200 to avoid
# user enumeration, but no email is actually sent. For prod you want both set.

# [SECRET] [E G]  optional (recommended). Gmail account used as From: header.
GMAIL_USER=REPLACE_ME_no-reply@your-domain.com

# [SECRET] [E G]  optional (recommended). Gmail app password (NOT the account
# password — generate at https://myaccount.google.com/apppasswords with 2FA on).
GMAIL_APP_PASSWORD=REPLACE_ME_gmail_app_password_16_chars

# ============================================================================
# 4. Dandanplay API (anime episode + danmaku matching)
# ============================================================================

# [SECRET] [E G]  required for /api/dandanplay/* endpoints. Register at
# https://www.dandanplay.com/ to obtain. Without these, danmaku lookup +
# manual episode selection silently return empty results.
DANDANPLAY_APP_ID=REPLACE_ME_dandanplay_app_id
DANDANPLAY_APP_SECRET=REPLACE_ME_dandanplay_app_secret

# ============================================================================
# 5. Sentry (error reporting)
# ============================================================================
# CRITICAL: VPS → sentry.io network may be blocked at the upstream
# (HK LucidaCloud route). Server-side Sentry can fail silently — see
# project_vps_sentry_block.md memo. Client-side (NEXT_PUBLIC) is unaffected
# because it ships from the browser.

# [INFRA] [BUILD] [N]  optional. Inlined into the next-app client bundle at
# build time. To change, you MUST rebuild the next-app image.
NEXT_PUBLIC_SENTRY_DSN=

# [SECRET] [BUILD] [N]  optional. Used by @sentry/nextjs at build to upload
# sourcemaps. To change, you MUST rebuild the next-app image.
# Generate at https://your-org.sentry.io/settings/account/api/auth-tokens/
SENTRY_AUTH_TOKEN=

# [INFRA] [E N G]  optional. Server-side DSN for Express, next-app server,
# and go-api. Runtime read — restart is enough to pick up changes.
SENTRY_DSN=

# [INFRA] [G]  optional (Sentry environment tag). e.g. "production", "staging".
APP_ENV=production

# [INFRA] [G]  optional (Sentry release tag). Inject from CI as the deploy
# git SHA so issues group per release. Leave empty for manual deploys.
GIT_SHA=

# ============================================================================
# 6. Rate limiting
# ============================================================================

# [INFRA] [E G]  optional. Max auth attempts per window (login/register/
# refresh). Both Express and go-api honor this so dual-accept stays
# symmetric. Default differs per runtime; set explicitly for predictability.
AUTH_RATELIMIT_MAX=20

# [INFRA] [G]  optional. Generic API burst ceiling for go-api's token-bucket
# limiter. Default is permissive; set lower for stricter abuse control.
API_RATELIMIT_BURST=100

# ============================================================================
# 7. Runtime (mostly redundant with compose env: blocks — kept for
#    services without per-service overrides and for non-compose runs)
# ============================================================================

# [INFRA] [E N W G]  required. Drives:
#   - Express: CORS strict mode, cookie Secure flag
#   - next-app: production routing (rewrites disabled), Sentry env
#   - cookie SameSite=None+Secure path
# next-app's compose block ALSO sets NODE_ENV=production explicitly, so this
# is mainly for Express + ws-server which inherit purely from env_file.
NODE_ENV=production

# [INFRA] [G]  required for go-api cookies to set Secure + SameSite=none.
# Without this, next-app SSR can't read the cross-origin session cookie →
# users appear logged-out in SSR even with a valid token.
GO_ENV=production

# [INFRA] [E]  optional (default 5001). Express HTTP port (internal; nginx
# proxies to it).
PORT=5001

# [INFRA] [G]  optional (default 8080). compose pins this to 8080 already.
PORT_GO=8080

# [INFRA] [W]  optional (default 3001). compose pins this to 3001 already.
PORT_WS=3001

# [INFRA] [N]  set by compose to Asia/Shanghai. Listed here for reference
# only — Express + go-api inherit container TZ, no app code reads this var.
# TZ=Asia/Shanghai

# [INFRA] [N]  set by compose to 0.0.0.0 so the Next standalone server binds
# the IPv4 wildcard (healthcheck uses 127.0.0.1; see compose comment).
# HOSTNAME=0.0.0.0

# ============================================================================
# 8. CORS + host allowlist (Express anti-scraping)
# ============================================================================

# [INFRA] [E G W]  required. Browser-side origin for CORS allow-list. Used by
# Express, go-api, AND ws-server (socket.io handshake CORS).
CLIENT_ORIGIN=https://animegoclub.com

# [INFRA] [E]  required (default "animegoclub.com,localhost"). Comma-separated
# Host-header allow-list. Express returns 403 if Host is not in this list.
# MANDATORY entries:
#   - animegoclub.com   browser requests via nginx
#   - localhost         local docker-compose smoke testing
#   - app               Docker service name — next-app RSC fetch target
# Forgetting `app` = every SSR page blank (403 on the internal fetch) with
# NO 5xx alert. Do not omit.
ALLOWED_HOSTS=animegoclub.com,localhost,app

# [INFRA] [E]  optional (default animegoclub.com). Canonical host used by
# the Express SSR redirect middleware to 301 alt hosts → primary.
CANONICAL_HOST=animegoclub.com

# [INFRA] [E]  optional (default https://animegoclub.com). Base URL embedded
# in the sitemap.xml + robots.txt the Express middleware serves.
SITE_URL=https://animegoclub.com

# ============================================================================
# 9. Misc
# ============================================================================

# [INFRA] [E]  optional (default 24). AniList API in-memory cache TTL hours.
CACHE_TTL_HOURS=24

# ============================================================================
# Internal-only (set by docker-compose `environment:` blocks, NOT here)
# ============================================================================
# These exist for awareness — do not add them to .env.production. They are
# pinned in docker-compose.yml so the env file can't drift them:
#
#   GO_API_INTERNAL_URL  next-app → http://app:5001 (P9 flip → http://go-api:8080)
#   NEXT_TELEMETRY_DISABLED  next-app → 1
#   POSTGRES_DB              postgres service → animego
#   POSTGRES_USER            postgres service → animego
#
# R2 backup credentials are NOT here. rclone reads them from
# ~/.config/rclone/rclone.conf on the host.
