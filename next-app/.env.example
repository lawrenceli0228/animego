# next-app local env overrides.  Copied by developers to next-app/.env.local
# (gitignored by Next).  All variables here are read by server-side code
# (RSC, server actions, route handlers), not bundled into the browser unless
# prefixed with NEXT_PUBLIC_.

# Internal go-api URL for RSC fetch.  In dev this points at the local
# go-api container/port; in prod the docker-compose service name resolves
# inside the network (e.g., http://go-api:8080).  Browser requests always
# go through next dev rewrites or nginx and never see this URL.
GO_API_INTERNAL_URL=http://localhost:8080

# Sentry DSNs.  Leave empty during local dev -- the SDK no-ops gracefully
# when DSN is falsy.  In prod, populate from the project settings page on
# sentry.io.  NEXT_PUBLIC_ prefix is required for the browser bundle to
# pick it up; the bare SENTRY_DSN is server-only.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Sentry auth token for source-map upload at build time.  Without this,
# source-map upload is skipped and the build still succeeds (see
# next.config.ts -> sourcemaps.disable).  Get from sentry.io -> Settings
# -> Auth Tokens.  Required for prod CI builds; optional for dev.
SENTRY_AUTH_TOKEN=
