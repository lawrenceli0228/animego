{
  "name": "animego",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:next": "cd next-app && bun --bun next dev",
    "build:next": "cd next-app && bun --bun next build",
    "build": "npm run build --workspace=client",
    "start": "npm start --workspace=server"
  },
  "dependencies": {
    "pako": "^2.1.0"
  }
}
