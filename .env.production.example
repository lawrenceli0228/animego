# ──────────────────────────────────────────────────────────────────
#  AnimeGo prod .env (v2.0.x live; Go + Postgres + next-app added at cutover)
#
#  Until P9 cutover: only the v2.0.x block is active.
#  At cutover: the Go + Postgres block becomes the source of truth;
#  MONGODB_URI lingers for 30d read-only as the rollback safety net,
#  then removed per MIGRATION_PLAN.md § Phase 9 T+30 day.
#
#  Three services will share JWT_SECRET + DATABASE_URL after cutover:
#    - go-api    (Go HTTP API)
#    - ws-server (socket.io danmaku)
#    - next-app  (Next.js 16 SSR, replaces Vite client at P10 retire)
# ──────────────────────────────────────────────────────────────────

# ─── Shared ───
# JWT signing key. Same value used by Express, Go, ws-server, and next-app
# middleware (next-app verifies access tokens server-side for SSR auth).
JWT_SECRET=<your-jwt-secret-256-bits-hex>
JWT_REFRESH_SECRET=<your-jwt-refresh-secret-256-bits-hex>
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
DANDANPLAY_APP_ID=<your-dandanplay-app-id>
DANDANPLAY_APP_SECRET=<your-dandanplay-app-secret>

# ─── v2.0.x (Express + Mongo) — active until P9 cutover ───
# TODO(P9 T+30 day): delete MONGODB_URI after Mongo read-only window expires.
# Until cutover this is the source of truth. After cutover keep for 30d
# rollback safety net (read-only), then remove per MIGRATION_PLAN.md § P9.
MONGODB_URI=mongodb://mongodb:27017/animego
PORT=5001
# CLIENT_ORIGIN is the CORS allow-list consumed by Express, Go API, and ws-server.
# Production domain is the public site; nginx fronts both old (Express) and new
# (next-app) until P10 retires Vite SPA.
CLIENT_ORIGIN=https://animegoclub.com
CACHE_TTL_HOURS=24
NODE_ENV=production

# ─── ALLOWED_HOSTS (P8.1 cutover — REQUIRED, do not omit) ───
# Express anti-scraping middleware (server/index.js) rejects any
# request whose Host header is NOT in this comma-separated list with
# a 403 Forbidden. next-app's RSC fetches go to http://app:5001 via
# Docker DNS, so the Host header IS literally `app`. If you forget to
# add `app` here, every server-rendered page on next-app gets empty
# data with a 403 in the next-app logs — the site renders but every
# section is blank, and no 5xx alert fires because Express returns
# 403 (not 5xx).
#
# Mandatory entries:
#   animegoclub.com  (public domain — browser requests)
#   localhost        (local docker-compose smoke testing)
#   app              (Docker service name — next-app RSC fetch target)
#
# If you add a sibling next-app instance for canary, add its service
# name here too.
ALLOWED_HOSTS=animegoclub.com,localhost,app

# ─── Go + Postgres (activates at P9 cutover) ───
# POSTGRES_PASSWORD must be a strong unique value; do NOT reuse devpassword.
# POSTGRES_PASSWORD=<strong-random-32-bytes>
#
# DATABASE_URL is shared by go-api pgxpool (request handlers + river queue,
# same pool) and the migrate tool. River queue (P2.6 bangumi_v3) has NO
# separate URL — it reuses this pgxpool.
# DATABASE_URL=postgres://animego:<strong-random>@postgres:5432/animego?sslmode=disable
#
# PORT_GO=8080
# PORT_WS=3001

# ─── Next.js 16 (P3+, activates when next-app replaces Vite at P10 retire) ───
# In prod, next-app runs behind nginx; rewrites are disabled in next.config.ts
# (return [] when NODE_ENV=production) — nginx routes /api/* to go-api directly.
# Reserved for future SSR-side public bases if needed (default: leave unset):
# NEXT_PUBLIC_API_BASE=https://animegoclub.com
# NEXT_PUBLIC_WS_BASE=https://animegoclub.com

# ─── R2 backup (rclone reads ~/.config/rclone/rclone.conf; here for reference only) ───
# R2 access keys live in rclone.conf, NOT in this env file.
