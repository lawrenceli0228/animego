# Deploy-time secrets — NEVER commit (.gitignore blocks .env.deploy).
#
# Used by VPS deploy / migration runbooks under docs/deploy/.
# Copy to .env.deploy locally, fill real values, then source it:
#
#   cp .env.deploy.example .env.deploy
#   chmod 600 .env.deploy
#   source .env.deploy
#
# After sourcing, commands in the runbook that reference $OLD_IP / $NEW_IP /
# $OLD_SSH_PORT / $NEW_SSH_PORT will expand to real values.

# ─── Old VPS (the box currently serving prod) ───
OLD_IP=
OLD_SSH_PORT=22

# ─── New VPS (the box you're migrating to) ───
NEW_IP=
NEW_SSH_PORT=22

# ─── Throwaway addresses for smoke testing ───
# A real mailbox you can check during §5 SMTP smoke
SMOKE_TEST_EMAIL=
