# Dependencies
node_modules/
# bun lockfile — local dev tool only. Production Docker uses npm ci
# against package-lock.json, which is the source of truth.
bun.lock
bun.lockb

# Exception: next-app/bun.lock IS tracked (Phase 3 dual-rail per
# MIGRATION_PLAN.md §Phase 3 lockfile 双轨; pre-commit hook in P3.1
# will enforce mtime sync with package-lock.json)
!next-app/bun.lock

# Environment variables (contains secrets - never commit)
.env
.env.local
.env.production
.env.deploy

# Internal docs — kept local only (含 deploy runbook + 设计 + 迁移笔记，
# 可能含 IP/port/路径/账号等 operational 细节，公开仓库一律不入)
docs/

# Build output
client/dist/
client/build/

# Logs
*.log
npm-debug.log*

# OS
.DS_Store

# IDE
.vscode/
.idea/
.gstack/

# Database backups
*.archive

# Project docs (contain sensitive deployment info)
CHANGELOG.md
CLAUDE.md
.claude/
scripts/setup.sh

# Scratch / local-only artifacts
.gstack-screenshots/
.context/
demos/
docs/designs/implementAnimeGPT.md

# migrate-mongo runtime artifacts (failure log written by orchestrator)
go-api/migrate-failures.jsonl
migrate-failures.jsonl

# P1.E prod mongodump pulled from VPS (sensitive: user data)
*-prod-mongodump-*.archive.gz
/tmp/animego-prod-mongodump*

# Go-built binaries (output of `go build ./cmd/<name>` — runtime uses
# the docker image, host-built binaries are local artifacts only).
go-api/parity-check
go-api/migrate-mongo
go-api/server

# Per-phase status / progress / design docs — generated locally, not part of source tree.
# Already-committed P0/P1/P2-PROGRESS files remain (git ignore does not touch tracked files).
docs/migration/*STATUS*
docs/migration/PHASE*-STATUS*
docs/migration/PHASE*-COMPLETE*
docs/migration/LOCAL-TEST*
docs/**/*-DESIGN.md
docs/**/*-DESIGN.html
docs/migration/P*-PROGRESS.md
docs/migration/P*-PROGRESS.html

# BASELINE raw data dumps (lighthouse JSON, nginx logs, etc.) — local-only
# for reproducibility; the distilled numbers live in BASELINE.md itself.
docs/migration/data/

# nginx self-signed cert — generated locally + on the VPS independently.
# Prod uses Let's Encrypt via the deploy script. Local dev uses openssl
# self-signed (browser cert warning, accept once).
nginx/selfsigned.crt
nginx/selfsigned.key
