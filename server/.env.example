# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/animego?retryWrites=true&w=majority

# JWT secrets (generate with: openssl rand -base64 32)
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=5001
NODE_ENV=production

# CORS — in Docker deployment, frontend is served by Express itself (same origin),
# so this can be left empty or set to your domain for extra safety.
CLIENT_ORIGIN=https://your-domain.com

# Cache
CACHE_TTL_HOURS=24
